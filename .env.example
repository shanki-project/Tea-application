# Copy this file to `.env` and adjust values. NEVER commit the real .env.
# ----------------------------------------------------------------------------

# --- App ---
ENVIRONMENT=development          # development | staging | production
DEBUG=true
CORS_ORIGINS=*                   # comma-separated origins in prod, e.g. https://assamtea.com
BACKEND_PORT=8000
WEB_CONCURRENCY=2                # gunicorn worker processes

# --- MySQL ---
# These are shared by the db container and the backend.
MYSQL_HOST=db                    # 'db' inside docker-compose; 'localhost' for local-venv runs
MYSQL_PORT=3306
MYSQL_DB=assamtea
MYSQL_USER=assamtea
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-root-password
