# Copy this file to `.env` and adjust values. NEVER commit the real .env.
# ----------------------------------------------------------------------------

# --- App ---
ENVIRONMENT=development          # development | staging | production
DEBUG=true
CORS_ORIGINS=*                   # comma-separated origins in prod, e.g. https://shankistea.com
BACKEND_PORT=8000
WEB_CONCURRENCY=2                # gunicorn worker processes

# --- Auth / JWT ---
# Generate a strong secret: `openssl rand -hex 32`
SECRET_KEY=change-me-dev-secret-not-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- MySQL ---
# 'db' inside docker-compose; 'localhost' for a local (non-Docker) MySQL install.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=shankistea
MYSQL_USER=shankis
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# --- First Super Admin (created by scripts/seed.py) ---
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=superadmin@shankistea.com
SUPERADMIN_PASSWORD=ChangeMe123!
